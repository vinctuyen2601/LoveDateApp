{
  "expo": {
    "name": "LoveDate",
    "slug": "important-dates-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF8E8E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lovedate.mobile",
      "icon": "./assets/icon.png",
      "buildNumber": "9",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification", "fetch", "processing"],
        "BGTaskSchedulerPermittedIdentifiers": ["BACKGROUND_NOTIFICATION_TASK"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 15,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF8E8E"
      },
      "package": "com.lovedate.mobile",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ứng dụng cần quyền truy cập thư viện ảnh để chọn ảnh đại diện."
        }
      ],
      "expo-font",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-task-manager",
      "expo-background-fetch",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          }
        }
      ],
      "./plugins/withFirebasePodfileFix"
    ],
    "extra": {
      "eas": {
        "projectId": "2a3a23a7-ec2f-4fba-931b-2adb02ad9c6c"
      }
    },
    "owner": "tuyen2601"
  }
}
